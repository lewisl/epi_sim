{
    "$schema": "http://json-schema.org/draft-06/schema#",
    "$ref": "#/definitions/Welcome",
    "definitions": {
        "Welcome": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "vaxesincluded": {
                    "$ref": "#/definitions/Vaxesincluded"
                },
                "dayrange": {
                    "type": "array",
                    "items": {
                        "type": "integer"
                    }
                },
                "targetpct": {
                    "type": "number"
                },
                "filtervec": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "shotmode": {
                    "type": "string"
                },
                "pattern": {
                    "type": "array",
                    "items": {
                        "type": "number"
                    }
                },
                "spreadfunc": {
                    "type": "null"
                }
            },
            "required": [
                "dayrange",
                "filtervec",
                "pattern",
                "shotmode",
                "spreadfunc",
                "targetpct",
                "vaxesincluded"
